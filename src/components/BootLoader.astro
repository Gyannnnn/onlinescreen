---
import type { BootLoaderDotsConfig } from '../data/boot-screens';

type Props = {
  config: BootLoaderDotsConfig;
  class?: string;
};

const { config, class: className } = Astro.props;
const isUbuntuBoot = config.animation === 'ubuntuBoot';

let ubuntuStyles = '';
if (isUbuntuBoot) {
  const count = config.count;
  const stepPct = 100 / (count * 2);
  const rules: string[] = [];
  for (let i = 0; i < count; i++) {
    const onStart = i * stepPct;
    const onEnd = (i + count) * stepPct;
    const name = `bs-ubuntu-dot-${i}`;
    if (onStart === 0) {
      rules.push(
        `@keyframes ${name}{0%,0.01%{background:#fff;box-shadow:none}0.01%,${onEnd}%{background:#c8431a;box-shadow:0 0 6px rgba(200,67,26,0.45)}${onEnd}%,100%{background:#fff;box-shadow:none}}`,
      );
    } else {
      rules.push(
        `@keyframes ${name}{0%,${onStart}%{background:#fff;box-shadow:none}${onStart}%,${onEnd}%{background:#c8431a;box-shadow:0 0 6px rgba(200,67,26,0.45)}${onEnd}%,100%{background:#fff;box-shadow:none}}`,
      );
    }
  }
  ubuntuStyles = rules.join('');
}
---

{
  isUbuntuBoot && <Fragment set:html={`<style>${ubuntuStyles}</style>`} />
}

{
  config.type === 'dots' && (
    <div class={`bs-loader bs-loader-dots ${isUbuntuBoot ? 'bs-loader-ubuntu' : ''} ${className ?? ''}`} aria-hidden="true">
      <div class="bs-dots-row" style={`gap: ${config.gap}px;${isUbuntuBoot ? 'transform:translateX(-10px)' : ''}`}>
        {Array.from({ length: config.count }, (_, i) => {
          const animName = isUbuntuBoot ? `bs-ubuntu-dot-${i}` : 'bs-dot-pulse';
          const delay = isUbuntuBoot
            ? '0'
            : ((100 / config.count / 100) * i * config.duration).toFixed(0);
          return (
            <span
              class="bs-dot"
              style={`
                width: ${config.size}px;
                height: ${config.size}px;
                background: ${config.colors[i] ?? config.colors[0]};
                animation: ${animName} ${config.duration}ms ease-in-out ${delay}ms infinite;
              `}
            ></span>
          );
        })}
      </div>
    </div>
  )
}

<style is:global>
  @keyframes bs-dot-pulse {
    0% { opacity: 0.25; transform: scale(0.7); }
    4% { opacity: 0.25; transform: scale(0.7); }
    10% { opacity: 1; transform: scale(1); }
    16% { opacity: 1; transform: scale(1); }
    20% { opacity: 0.25; transform: scale(0.7); }
    100% { opacity: 0.25; transform: scale(0.7); }
  }
</style>

<style>
  .bs-loader-dots {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .bs-dots-row {
    display: flex;
    align-items: center;
  }
  .bs-dot {
    flex-shrink: 0;
    border-radius: 50%;
    will-change: background, box-shadow;
  }
</style>
