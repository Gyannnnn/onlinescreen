---
import ToolCard from './ToolCard.astro';
import { categories, popularTools, tools, type ToolCategoryId } from '../data/tools';
import { type Locale } from '../data/locales';
import { t, toolName } from '../data/translations';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const categoryIds = Object.keys(categories) as ToolCategoryId[];
---

<section class="site-shell py-20 md:py-28">
  <div class="max-w-4xl">
    <p class="font-mono text-xs text-muted">{t(locale, 'hero.eyebrow')}</p>
    <h1 class="mt-5 max-w-3xl text-5xl font-semibold leading-[0.95] text-balance text-ink md:text-7xl">
      {t(locale, 'hero.heading')}
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-body">
      {t(locale, 'hero.subtitle')}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a class="rounded-full bg-ink px-5 py-3 text-sm font-medium text-canvas hover:bg-body" href="#colors">{t(locale, 'hero.browse')}</a>
      <!-- <a class="rounded-full border border-hairline bg-canvas px-5 py-3 text-sm font-medium text-ink hover:bg-canvas-soft" href="/dead-pixel-test/">{t(locale, 'hero.run_test')}</a> -->
    </div>
  </div>
  <div class="mt-14 grid gap-4 sm:grid-cols-2 md:grid-cols-4">
    {popularTools.slice(0, 4).map((tool) => <ToolCard tool={tool} locale={locale} />)}
  </div>
</section>

<section class="border-y border-hairline bg-canvas">
  <div class="site-shell grid gap-8 py-14 md:grid-cols-3">
    <div>
      <p class="font-mono text-xs text-muted">{t(locale, 'analysis.eyebrow')}</p>
      <h2 class="mt-3 text-3xl font-semibold text-balance text-ink">{t(locale, 'analysis.heading')}</h2>
    </div>
    <div class="space-y-4 text-sm leading-6 text-body md:col-span-2">
      <p>
        {t(locale, 'analysis.p1')}
      </p>
      <p>
        {t(locale, 'analysis.p2')}
      </p>
    </div>
  </div>
</section>

{categoryIds.map((categoryId) => (
  <section id={categoryId} class="site-shell scroll-mt-24 py-16">
    <div class="max-w-2xl">
      <p class="font-mono text-xs text-muted">{categories[categoryId].name.toUpperCase()}</p>
      <h2 class="mt-3 text-3xl font-semibold text-balance text-ink">{categories[categoryId].name}</h2>
      <p class="mt-3 text-base leading-7 text-body">{categories[categoryId].description}</p>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {tools.filter((tool) => tool.category === categoryId).map((tool) => <ToolCard tool={tool} locale={locale} />)}
    </div>
  </section>
))}
