---
import type { Tool } from '../data/tools';
import { type Locale } from '../data/locales';
import { t } from '../data/translations';

type Props = { tool: Tool; locale: Locale; isCard?: boolean };
const { tool, locale, isCard = false } = Astro.props;
---

<div class="ht" id="ht" data-hacker-terminal data-is-card={isCard ? "true" : "false"} aria-label="Hacker Typer Terminal">
  <!-- Code Editor Window Frame -->
  <div class="ht-window">
    <!-- Window Titlebar -->
    <div class="ht-head">
      <div class="ht-dots">
        <span class="ht-dot red"></span>
        <span class="ht-dot yellow"></span>
        <span class="ht-dot green"></span>
      </div>
      <div class="ht-title">exploit-node — bash — 120×43</div>
    </div>

    <!-- IDE Sidebar + File Tree + Editor Pane Grid -->
    <div class="ht-body">
      <!-- Mini Side Icon Bar -->
      <div class="ht-sidebar-icons">
        <div class="ht-icon active" title="Explorer">📂</div>
        <div class="ht-icon" title="Search">🔍</div>
        <div class="ht-icon" title="Source Control">🌿</div>
        <div class="ht-icon" title="Extensions">🧩</div>
        <div class="ht-icon" style="margin-top: auto;" title="Settings">⚙️</div>
      </div>

      <!-- File tree panel -->
      <div class="ht-file-tree" id="htFileTree">
        <div class="tree-header">WORKSPACE</div>
        <div class="tree-root">📁 exploit-kit</div>
        <div class="tree-file active" data-file-key="exploit">
          <span>📄</span> cve_exploit.c
        </div>
        <div class="tree-file" data-file-key="sniffer">
          <span>📄</span> sniffer.py
        </div>
        <div class="tree-file" data-file-key="cracker">
          <span>📄</span> brute_force.go
        </div>
      </div>

      <!-- Main Editor view -->
      <div class="ht-editor">
        <!-- Editor view Tab bar -->
        <div class="ht-tab-bar" id="htTabBar">
          <div class="ht-tab active" data-file-key="exploit">cve_exploit.c <span class="tab-close">×</span></div>
          <div class="ht-tab" data-file-key="sniffer">sniffer.py <span class="tab-close">×</span></div>
          <div class="ht-tab" data-file-key="cracker">brute_force.go <span class="tab-close">×</span></div>
        </div>

        <!-- Scrollable editor pane -->
        <div class="ht-code-view" id="htCodeView">
          <div class="ht-line-numbers" id="htLineNumbers">
            {isCard ? (
              <><div>1</div><div>2</div><div>3</div><div>4</div><div>5</div><div>6</div><div>7</div><div>8</div></>
            ) : (
              <div>1</div>
            )}
          </div>
          <div class="ht-editor-content">
            <pre class="ht-pre"><code id="htCodeArea">{isCard && `#include <stdio.h>
#define COMMIT_CREDS 0xffffffff810b42f6
void get_root() {
    _commit_creds commit_creds = (_commit_creds)COMMIT_CREDS;
    commit_creds(prepare_kernel_creds(0));
}
int main() {
    printf("[+] Injecting ring-0 thread...\\n");`}</code><span class="ht-cursor" id="htCursor">_</span></pre>
          </div>
        </div>

        <!-- Terminal Exploit Action Overlay (Hidden by default, triggered on completion/button) -->
        <div class="ht-exploit-overlay hidden" id="htExploitOverlay">
          <div class="overlay-title">SYSTEM PRIVILEGE TERMINAL OVERFLOW</div>
          <div class="overlay-logs" id="htExploitLogs"></div>
          <div class="overlay-actions">
            <button class="overlay-btn red" id="htOverlayCloseBtn" type="button">DISMISS CONSOLE</button>
          </div>
        </div>

        <!-- Editor Status bar -->
        <div class="ht-status-bar">
          <div class="status-left">
            <span class="badge">admin@node-x1</span>
            <span class="branch">⎇ main*</span>
          </div>
          <div class="status-right">
            <span>Spaces: 4</span>
            <span>UTF-8</span>
            <span>C/C++</span>
            <span id="htCursorPos">Ln 1, Col 1</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick action controls panel -->
    <div class="ht-controls">
      <button class="ctrl-btn main" id="htFsBtn" type="button">
        ⛶ Fullscreen
      </button>
      <button class="ctrl-btn" id="htClearBtn" type="button">
        ⎚ Reset Area
      </button>
      <button class="ctrl-btn" id="htAutoBtn" type="button">
        ▶ Auto-Pilot
      </button>
      <button class="ctrl-btn red-glow" id="htExploitTriggerBtn" type="button">
        ⚡ Run Exploit
      </button>

      <div class="ctrl-item">
        <label for="htStyleSelect">MX Switch:</label>
        <select id="htStyleSelect">
          <option value="blue">Blue Switch (Clicky)</option>
          <option value="brown">Brown Switch (Tactile)</option>
          <option value="typewriter">Typewriter (Metallic)</option>
          <option value="mute">Muted</option>
        </select>
      </div>

      <div class="ctrl-item">
        <label for="htThemeSelect">Theme:</label>
        <select id="htThemeSelect">
          <option value="dark">VS Code Dark</option>
          <option value="monokai">Monokai Retro</option>
          <option value="amber">Amber Terminal</option>
          <option value="matrix">Matrix Green</option>
        </select>
      </div>

      <div class="ctrl-item">
        <label for="htSpeed">Speed:</label>
        <input type="range" id="htSpeed" min="1" max="15" value="6" class="speed-range" aria-label="Typing speed" />
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* Base Container Grid/Style */
  .ht {
    background: #181824;
    color: #a9b1d6;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    position: relative;
    width: 100%;
    height: 480px;
    border-radius: 8px;
    overflow: hidden;
    outline: none;
    box-sizing: border-box;
  }

  .ht-window {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }

  /* Linux/Mac Window Header bar */
  .ht-head {
    height: 38px;
    background: #1a1b26;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    border-bottom: 1px solid #10101a;
    cursor: default;
    user-select: none;
  }
  .ht-dots {
    display: flex;
    gap: 8px;
  }
  .ht-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .ht-dot.red { background: #ff5f56; }
  .ht-dot.yellow { background: #ffbd2e; }
  .ht-dot.green { background: #27c93f; }
  .ht-title {
    font-family: monospace;
    font-size: 12px;
    color: #787c99;
    flex: 1;
    text-align: center;
    margin-right: 36px;
  }

  .ht-body {
    flex: 1;
    display: flex;
    overflow: hidden;
    background: #1a1b26;
  }

  /* IDE Left Mini-sidebar */
  .ht-sidebar-icons {
    width: 48px;
    background: #16161e;
    border-right: 1px solid #24283b;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10px 0;
    gap: 18px;
  }
  .ht-icon {
    font-size: 20px;
    cursor: pointer;
    opacity: 0.45;
    transition: opacity 0.15s;
    user-select: none;
  }
  .ht-icon.active, .ht-icon:hover {
    opacity: 0.95;
  }

  /* IDE File tree explorer panel */
  .ht-file-tree {
    width: 156px;
    background: #1e1e2e;
    border-right: 1px solid #24283b;
    padding: 12px 6px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: #a9b1d6;
    user-select: none;
  }
  .ht .tree-header {
    font-size: 9px;
    font-weight: bold;
    color: #565f89;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
    padding-left: 6px;
  }
  .ht .tree-root {
    font-weight: 600;
    padding-left: 4px;
    margin-bottom: 4px;
  }
  .ht .tree-file {
    padding: 6px 8px;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ht .tree-file:hover {
    background: rgba(255, 255, 255, 0.05);
  }
  .ht .tree-file.active {
    background: rgba(41, 121, 255, 0.15);
    color: #4196ff;
  }

  .ht-editor {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* Tabs Navigation list */
  .ht-tab-bar {
    height: 35px;
    background: #16161f;
    display: flex;
    border-bottom: 1px solid #24283b;
    overflow-x: auto;
    user-select: none;
  }
  .ht-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    font-size: 12px;
    color: #787c99;
    border-right: 1px solid #1f2335;
    background: #1a1b26;
    cursor: pointer;
    white-space: nowrap;
  }
  .ht-tab.active {
    background: #1e1e2e;
    color: #a9b1d6;
    border-bottom: 2px solid #3d59a1;
  }
  .ht .tab-close {
    font-size: 11px;
    opacity: 0.5;
  }
  .ht .tab-close:hover {
    opacity: 1;
  }

  /* Scrolling code workspace area */
  .ht-code-view {
    flex: 1;
    display: flex;
    font-family: inherit;
    overflow: auto;
    background: #1e1e2e;
    font-size: 13px;
    line-height: 1.5;
  }

  .ht-line-numbers {
    width: 32px;
    text-align: right;
    padding: 16px 8px 16px 0;
    color: #565f89;
    font-family: Menlo, Monaco, Consolas, "Fira Code", monospace;
    font-size: 11px;
    border-right: 1px solid rgba(255, 255, 255, 0.04);
    user-select: none;
  }

  .ht-editor-content {
    flex: 1;
    padding: 16px 12px;
  }

  .ht-pre {
    margin: 0;
    font-family: Menlo, Monaco, Consolas, "Fira Code", monospace;
    white-space: pre-wrap;
    word-break: break-all;
    text-align: left;
    color: #9ece6a; /* Default light green */
  }

  /* Styled Cursor effect */
  .ht-cursor {
    color: #2ac3de;
    animation: ht-blink 0.9s step-end infinite;
    font-weight: bold;
    display: inline-block;
    width: 6px;
  }

  @keyframes ht-blink {
    50% { opacity: 0; }
  }

  /* Console privilege output overlay */
  .ht-exploit-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 10;
    display: flex;
    flex-direction: column;
    padding: 20px;
    text-align: left;
    font-family: monospace;
    font-size: 12px;
    color: #2ac3de;
  }
  .ht-exploit-overlay.hidden {
    display: none !important;
  }

  .ht .overlay-title {
    font-size: 14px;
    font-weight: bold;
    color: #f7768e;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    padding-bottom: 8px;
    margin-bottom: 12px;
    letter-spacing: 0.5px;
  }

  .ht .overlay-logs {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 4px;
    line-height: 1.4;
    color: rgb(0, 240, 0);
  }

  .ht .overlay-actions {
    margin-top: 12px;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.1);
    display: flex;
    justify-content: flex-end;
  }

  .ht .overlay-btn {
    border-radius: 4px;
    padding: 6px 16px;
    font-size: 11px;
    font-family: monospace;
    font-weight: bold;
    cursor: pointer;
    border: none;
  }
  .ht .overlay-btn.red {
    background: #ff5f56;
    color: #fff;
  }

  /* Workspace Status Bar */
  .ht-status-bar {
    height: 24px;
    background: #16161f;
    border-top: 1px solid #24283b;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 10px;
    font-size: 11px;
    color: #565f89;
    user-select: none;
  }
  .ht .status-left, .ht .status-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ht .badge {
    background: #24283b;
    color: #a9b1d6;
    padding: 1px 6px;
    border-radius: 2px;
  }
  .ht .branch {
    color: #2ac3de;
  }

  /* Control buttons in base panel */
  .ht-controls {
    background: #111116;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 10px 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    user-select: none;
  }
  .ht .ctrl-btn {
    background: #24283b;
    color: #c0caf5;
    border: 1px solid #383e56;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .ht .ctrl-btn:hover {
    background: #2f354e;
    color: #fff;
  }
  .ht .ctrl-btn.main {
    background: #4196ff;
    color: #fff;
    border-color: #2979ff;
  }
  .ht .ctrl-btn.main:hover {
    background: #1e71ff;
  }
  .ht .ctrl-btn.red-glow {
    background: #ff5f56;
    color: #fff;
    border-color: #e04c44;
  }
  .ht .ctrl-btn.red-glow:hover {
    background: #e04c44;
    box-shadow: 0 0 12px rgba(255, 95, 86, 0.45);
  }

  .ht .ctrl-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: #787c99;
  }
  .ht .ctrl-item select {
    background: #24283b;
    color: #c0caf5;
    border: 1px solid #383e56;
    border-radius: 4px;
    padding: 3px 6px;
    font-size: 11px;
    outline: none;
  }
  .ht .speed-range {
    width: 70px;
    accent-color: #2ac3de;
    height: 4px;
  }

  /* Fullscreen overrides */
  .ht.is-fullscreen {
    position: fixed !important;
    inset: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    z-index: 99999 !important;
    border-radius: 0 !important;
    border: none !important;
  }
  .ht.is-fullscreen .ht-window {
    border-radius: 0 !important;
  }
  .ht.is-fullscreen .ht-status-bar {
    height: 28px;
    font-size: 12px;
  }
  .ht.is-fullscreen .ht-controls {
    display: none !important;
  }

  /* Themes overrides */
  .ht.theme-monokai .ht-pre { color: #a6e22e; }
  .ht.theme-monokai .ht-cursor { color: #f92672; }
  .ht.theme-monokai .ht-code-view { background: #272822; }
  .ht.theme-monokai .ht-line-numbers { color: #75715e; }

  .ht.theme-amber .ht-pre { color: #ffb000; }
  .ht.theme-amber .ht-cursor { color: #ffb000; }
  .ht.theme-amber .ht-code-view { background: #120b00; }
  .ht.theme-amber .ht-line-numbers { color: #9A6a00; }

  .ht.theme-matrix .ht-pre { color: #00ff41; font-weight: bold; }
  .ht.theme-matrix .ht-cursor { color: #00ff41; }
  .ht.theme-matrix .ht-code-view { background: #000; }
  .ht.theme-matrix .ht-line-numbers { color: #00661a; }

  /* Card Mode Overrides */
  .ht[data-is-card="true"] {
    height: 100% !important;
    border-radius: 0 !important;
    outline: none !important;
  }
  .ht[data-is-card="true"] .ht-window {
    border-radius: 0 !important;
  }
  .ht[data-is-card="true"] .ht-controls {
    display: none !important;
  }
  .ht[data-is-card="true"] .ht-body {
    transform: scale(0.85);
    transform-origin: top left;
    width: 118%;
    height: 118%;
  }
  .ht[data-is-card="true"] .ht-file-tree {
    width: 110px !important;
  }
</style>

<script is:inline>
  (function () {
    const root = document.getElementById("ht");
    const codeArea = document.getElementById("htCodeArea");
    const lineNumbers = document.getElementById("htLineNumbers");
    const codeView = document.getElementById("htCodeView");

    // Controls
    const fsBtn = document.getElementById("htFsBtn");
    const clearBtn = document.getElementById("htClearBtn");
    const autoBtn = document.getElementById("htAutoBtn");
    const triggerBtn = document.getElementById("htExploitTriggerBtn");
    const overlay = document.getElementById("htExploitOverlay");
    const overlayClose = document.getElementById("htOverlayCloseBtn");
    const logsContainer = document.getElementById("htExploitLogs");

    const styleSelect = document.getElementById("htStyleSelect");
    const themeSelect = document.getElementById("htThemeSelect");
    const speedInput = document.getElementById("htSpeed");
    const cursorPosVal = document.getElementById("htCursorPos");

    // File structure data
    const fileBuffers = {
      exploit: `#include <stdio.h>
