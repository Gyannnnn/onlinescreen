    // Line number manager
    function updateLineNumbers() {
      const codeText = codeArea.textContent || "";
      const linesCount = codeText.split("\n").length;
      let html = "";
      for (let i = 1; i <= linesCount; i++) {
        html += `<div>${i}</div>`;
      }
      lineNumbers.innerHTML = html;
      
      // Update cursor coordinate display
      const col = codeText.substring(codeText.lastIndexOf("\n") + 1).length + 1;
      cursorPosVal.textContent = `Ln ${linesCount}, Col ${col}`;
    }

    // Tab switcher
    function switchTab(key) {
      if (inExploitSimulation) return;
      activeFile = key;
      
      // Toggle Tab navigation UI
      document.querySelectorAll(".ht-tab").forEach(tab => {
        tab.classList.toggle("active", tab.getAttribute("data-file-key") === key);
      });
      document.querySelectorAll(".tree-file").forEach(file => {
        file.classList.toggle("active", file.getAttribute("data-file-key") === key);
      });

      // Clear & rebuild output
      const idx = indices[key];
      const buffer = fileBuffers[key];
      codeArea.textContent = buffer.substring(0, idx);
      updateLineNumbers();
      codeView.scrollTop = codeView.scrollHeight;
    }

    // Hook tab clicks
    document.querySelectorAll(".ht-tab").forEach(tab => {
      tab.addEventListener("click", function(e) {
        e.stopPropagation();
        switchTab(tab.getAttribute("data-file-key"));
      });
    });
    document.querySelectorAll(".tree-file").forEach(file => {
      file.addEventListener("click", function(e) {
        e.stopPropagation();
        switchTab(file.getAttribute("data-file-key"));
      });
    });

    // Write text
    function typeCharacters(count) {
      if (inExploitSimulation) return;
      
      const buffer = fileBuffers[activeFile];
      let idx = indices[activeFile];
      
      if (idx >= buffer.length) {
        // loop back
        idx = 0;
      }
      
      const chunk = buffer.substring(idx, idx + count);
      codeArea.textContent += chunk;
      indices[activeFile] = idx + count;
      
      updateLineNumbers();
      codeView.scrollTop = codeView.scrollHeight;

      // Automatically trigger exploit popup after typing a complete block of 350 chars
      if (indices[activeFile] > 350 && Math.random() < 0.05) {
        triggerExploitSim();
      }
    }

    // Mechanical keypress switch sounds synthesizer
    function initAudio() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      }
    }

    function playKeyAudio() {
      if (mxSwitchType === "mute") return;
      initAudio();
      if (!audioCtx) return;
      if (audioCtx.state === "suspended") audioCtx.resume();
      
      const t = audioCtx.currentTime;

      if (mxSwitchType === "blue") {
        // Cherry MX Blue Sound: Quick metallic click + housing switch puff
        const osc = audioCtx.createOscillator();
        const gain1 = audioCtx.createGain();
        osc.type = "sine";
        osc.frequency.setValueAtTime(5800 + Math.random() * 800, t);
        
        gain1.gain.setValueAtTime(0.02 * volume, t);
        gain1.gain.exponentialRampToValueAtTime(0.001, t + 0.006);
        
        osc.connect(gain1);
        gain1.connect(audioCtx.destination);
        osc.start(t);
        osc.stop(t + 0.008);

        // Plastic casing thud sound
        const bufferSize = audioCtx.sampleRate * 0.015;
        const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }
        
        const noise = audioCtx.createBufferSource();
        noise.buffer = buffer;
        const filter = audioCtx.createBiquadFilter();
        filter.type = "bandpass";
        filter.frequency.setValueAtTime(1200 + Math.random() * 300, t);
        filter.Q.setValueAtTime(3.0, t);

        const gain2 = audioCtx.createGain();
        gain2.gain.setValueAtTime(0.07 * volume, t);
        gain2.gain.exponentialRampToValueAtTime(0.001, t + 0.012);

        noise.connect(filter);
        filter.connect(gain2);
        gain2.connect(audioCtx.destination);
        noise.start(t);
        noise.stop(t + 0.015);

      } else if (mxSwitchType === "brown") {
        // Cherry MX Brown: Only plastic housing thud
        const bufferSize = audioCtx.sampleRate * 0.025;
        const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }
        
        const noise = audioCtx.createBufferSource();
        noise.buffer = buffer;
        const filter = audioCtx.createBiquadFilter();
        filter.type = "bandpass";
        filter.frequency.setValueAtTime(800 + Math.random() * 150, t);
        filter.Q.setValueAtTime(2.0, t);

        const gain = audioCtx.createGain();
        gain.gain.setValueAtTime(0.09 * volume, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.016);

        noise.connect(filter);
        filter.connect(gain);
        gain.connect(audioCtx.destination);
        noise.start(t);
        noise.stop(t + 0.02);

      } else if (mxSwitchType === "typewriter") {
        // Vintage Typewriter: Double metallic hammer strikes + spring reverb tail
        const osc1 = audioCtx.createOscillator();
        const gain1 = audioCtx.createGain();
        osc1.type = "triangle";
        osc1.frequency.setValueAtTime(1400 + Math.random() * 200, t);
        
        gain1.gain.setValueAtTime(0.03 * volume, t);
        gain1.gain.exponentialRampToValueAtTime(0.001, t + 0.04);
        
        osc1.connect(gain1);
        gain1.connect(audioCtx.destination);
        osc1.start(t);
        osc1.stop(t + 0.045);

        // Spring reverb ring
        const osc2 = audioCtx.createOscillator();
        const gain2 = audioCtx.createGain();
        osc2.type = "sine";
        osc2.frequency.setValueAtTime(320 + Math.random() * 50, t);
        
        gain2.gain.setValueAtTime(0.015 * volume, t);
        gain2.gain.exponentialRampToValueAtTime(0.001, t + 0.12);
        
        osc2.connect(gain2);
        gain2.connect(audioCtx.destination);
        osc2.start(t);
        osc2.stop(t + 0.13);
      }
    }

    // Privilege exploit simulator pop-up logs
    function triggerExploitSim() {
      if (inExploitSimulation) return;
      inExploitSimulation = true;
      stopAutoPilot();
      
      overlay.classList.remove("hidden");
      logsContainer.innerHTML = "";

      const exploitPhrases = [
        "[*] Establishing root console connection to remote client gateway...",
        "[*] SSH Handshake successful. Protocol version 2.0.",
        "[+] Target IP address allocated at: 10.0.12.89",
        "[*] Parsing local sys privileges ... Local UID = 1002 (gyan)",
        "[*] Triggering dirty-c0w vulnerability patch bypass...",
        "[*] Mapping virtual shared memory tables at address 0x7fffbc221000...",
        "[*] Overwriting cred struct mapping index arrays...",
        "[+] Syscall table patches applied correctly.",
        "[*] Escalating host privileges to admin scope...",
        "============================================================",
        "[!] SUCCESS: SYSTEM SHELL ESCALATED TO WHOAMI = ROOT (UID 0)",
        "============================================================",
        "[root@server-gateway-ch1]# id",
        "uid=0(root) gid=0(root) groups=0(root) context=unconfined",
        "[root@server-gateway-ch1]# echo \"Access Granted. System fully compromised.\"",
        "Access Granted. System fully compromised."
      ];

      initAudio();
      let logIdx = 0;
      function printNextLog() {
        if (!inExploitSimulation) return;
        if (logIdx >= exploitPhrases.length) return;

        const line = document.createElement("div");
        line.textContent = exploitPhrases[logIdx];
        
        // Critical alerts
        if (exploitPhrases[logIdx].startsWith("[!]")) {
          line.style.cssText = "color: #ff5f56; font-weight: bold; text-shadow: 0 0 4px rgba(255, 95, 86, 0.4);";
          // Play critical alarm chime sound
          if (audioCtx && mxSwitchType !== "mute") {
            const now = audioCtx.currentTime;
            const freqs = [520, 680, 880];
            freqs.forEach(f => {
              const osc = audioCtx.createOscillator();
              const g = audioCtx.createGain();
              osc.type = "sine";
              osc.frequency.setValueAtTime(f, now);
              g.gain.setValueAtTime(0.04 * volume, now);
              g.gain.exponentialRampToValueAtTime(0.001, now + 0.4);
              osc.connect(g);
              g.connect(audioCtx.destination);
              osc.start();
              osc.stop(now + 0.45);
            });
          }
        } else if (exploitPhrases[logIdx].startsWith("[+]")) {
          line.style.color = "#27c93f";
        }
        
        logsContainer.appendChild(line);
        logsContainer.scrollTop = logsContainer.scrollHeight;
        logIdx++;
        
        setTimeout(printNextLog, Math.random() * 300 + 150);
      }
      
      printNextLog();
    }

    // Auto-pilot
    function startAutoPilot() {
      if (autoPilotActive) return;
      autoPilotActive = true;
      if (autoBtn) {
        autoBtn.textContent = "⏸ Pause Auto";
        autoBtn.classList.add("main");
      }
      
      function runStep() {
        if (!autoPilotActive) return;
        typeCharacters(speed);
        playKeyAudio();
        
        const delay = Math.max(25, 300 - speed * 18);
        autoPilotTimer = setTimeout(runStep, delay);
      }
      runStep();
    }

    function stopAutoPilot() {
      autoPilotActive = false;
      if (autoPilotTimer) clearTimeout(autoPilotTimer);
      if (autoBtn) {
        autoBtn.textContent = "▶ Auto-Pilot";
        autoBtn.classList.remove("main");
      }
    }

    // Settings Panel Inputs hooks
    if (styleSelect) {
      styleSelect.addEventListener("change", function(e) {
        mxSwitchType = e.target.value;
      });
    }
    if (themeSelect) {
      themeSelect.addEventListener("change", function(e) {
        // Remove existing themes
        root.classList.remove("theme-monokai", "theme-amber", "theme-matrix");
        activeTheme = e.target.value;
        if (activeTheme !== "dark") {
          root.classList.add("theme-" + activeTheme);
        }
      });
    }
    if (speedInput) {
      speedInput.addEventListener("input", function(e) {
        speed = Number(e.target.value);
      });
    }

    // Action buttons click listeners
    if (clearBtn) {
      clearBtn.addEventListener("click", function(e) {
        e.stopPropagation();
        indices[activeFile] = 0;
        codeArea.textContent = "";
        updateLineNumbers();
        stopAutoPilot();
      });
    }
    if (autoBtn) {
      autoBtn.addEventListener("click", function(e) {
        e.stopPropagation();
        if (autoPilotActive) {
          stopAutoPilot();
        } else {
          startAutoPilot();
        }
      });
    }
    if (triggerBtn) {
      triggerBtn.addEventListener("click", function(e) {
        e.stopPropagation();
        triggerExploitSim();
      });
    }
    if (overlayClose) {
      overlayClose.addEventListener("click", function(e) {
        e.stopPropagation();
        overlay.classList.add("hidden");
        inExploitSimulation = false;
      });
    }

    // Fullscreen bindings
    function goFS() {
      if (!document.fullscreenElement) {
        root.requestFullscreen().catch(function () {});
      }
    }
    function exitFS() {
      if (document.fullscreenElement === root) {
        document.exitFullscreen().catch(function () {});
      }
    }

    if (fsBtn) {
      fsBtn.addEventListener("click", function(e) {
        e.stopPropagation();
        goFS();
      });
    }

    document.addEventListener("fullscreenchange", function () {
      const isFS = document.fullscreenElement === root;
      root.classList.toggle("is-fullscreen", isFS);
      
      if (!isFS) {
        stopAutoPilot();
      }
      setTimeout(updateLineNumbers, 80);
    });

    // Keyboard trigger typing hook
    document.addEventListener("keydown", function (e) {
      const key = e.key.toLowerCase();
      
      // Fullscreen checks
      if (document.fullscreenElement === root) {
        if (key === "escape") {
          exitFS();
        } else if (key === "1") {
          e.preventDefault(); switchTab("exploit");
        } else if (key === "2") {
          e.preventDefault(); switchTab("sniffer");
        } else if (key === "3") {
          e.preventDefault(); switchTab("cracker");
        } else if (key === "s") {
          e.preventDefault();
          mxSwitchType = (mxSwitchType === "mute") ? "blue" : "mute";
          if (styleSelect) styleSelect.value = mxSwitchType;
        } else if (key === "a") {
          e.preventDefault();
          if (autoPilotActive) stopAutoPilot();
          else startAutoPilot();
        } else if (key === "tab" || key === "enter") {
          e.preventDefault(); e.stopPropagation();
          triggerExploitSim();
        } else {
          // Type characters
          e.preventDefault();
          e.stopPropagation();
          typeCharacters(speed);
          playKeyAudio();
        }
        return;
      }

      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLSelectElement || e.target instanceof HTMLTextAreaElement) return;

      if (key === "f") {
        e.preventDefault();
        goFS();
      } else {
        // Standard typing inside preview container
        typeCharacters(speed);
        playKeyAudio();
      }
    });

    // Block right-clicks when in fullscreen mode
    document.addEventListener("contextmenu", function (e) {
      if (document.fullscreenElement === root) {
        e.preventDefault();
      }
    });

    // Initial lineup Setup
    updateLineNumbers();
  })();
</script>
)}
