---
import ToolCard from './ToolCard.astro';
import type { Tool } from '../data/tools';
import { type Locale } from '../data/locales';
import { t } from '../data/translations';

type Props = {
  tools: Tool[];
  locale: Locale;
};

const { tools, locale } = Astro.props;
---

<section class="site-shell py-16">
  <div class="flex items-end justify-between gap-6">
    <div>
      <p class="font-mono text-xs text-muted">{t(locale, 'tool.related')}</p>
      <h2 class="mt-3 text-3xl font-semibold text-balance text-ink">{t(locale, 'tool.related_heading')}</h2>
    </div>
    <a class="hidden rounded-full border border-hairline px-4 py-2 text-sm text-ink hover:bg-canvas sm:block" href="/">{t(locale, 'tool.all_tools')}</a>
  </div>
  <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {tools.map((tool) => <ToolCard tool={tool} locale={locale} />)}
  </div>
</section>
