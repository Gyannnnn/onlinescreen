---
import type { Tool } from '../data/tools';
import { type Locale } from '../data/locales';
import { t } from '../data/translations';

type Props = {
  tool: Tool;
  locale: Locale;
};

const { tool, locale } = Astro.props;
const color = tool.color ?? '#ffffff';
const mode = tool.id === 'gradient-screen' ? 'gradient'
           : tool.id === 'rgb-screen' ? 'rgb'
           : tool.id === 'hex-screen' ? 'hex'
           : 'solid';

const defaultColors = (() => {
  if (mode === 'gradient') return ['#007cf0', '#00dfd8'];
  if (mode === 'rgb') return ['#ff0000', '#00ff00', '#0000ff'];
  if (mode === 'hex') return ['#171717', '#7c3aed', '#ff0080', '#f9cb28'];
  return [color]; // solid
})();

const initialBackground = (() => {
  if (mode === 'gradient') return `linear-gradient(135deg, ${defaultColors[0]}, ${defaultColors[1]})`;
  if (mode === 'rgb') return `linear-gradient(90deg, ${defaultColors[0]} 0%, ${defaultColors[0]} 33.3%, ${defaultColors[1]} 33.3%, ${defaultColors[1]} 66.6%, ${defaultColors[2]} 66.6%, ${defaultColors[2]} 100%)`;
  if (mode === 'hex') return `linear-gradient(90deg, ${defaultColors[0]} 0%, ${defaultColors[0]} 25%, ${defaultColors[1]} 25%, ${defaultColors[1]} 50%, ${defaultColors[2]} 50%, ${defaultColors[2]} 75%, ${defaultColors[3]} 75%, ${defaultColors[3]} 100%)`;
  return color;
})();

const initialHsl = (() => {
  const activeCol = defaultColors[0];
  if (!activeCol.startsWith('#')) return 'hsl(210, 100%, 48%)';
  const clean = activeCol.replace('#', '');
  const number = Number.parseInt(clean, 16);
  const r = ((number >> 16) & 255) / 255;
  const g = ((number >> 8) & 255) / 255;
  const b = (number & 255) / 255;
  const max = Math.max(r, g, b);
  const min = Math.min(r, g, b);
  let h = 0;
  let s = 0;
  const l = (max + min) / 2;
  if (max !== min) {
    const d = max - min;
    s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
    if (max === r) h = (g - b) / d + (g < b ? 6 : 0);
    if (max === g) h = (b - r) / d + 2;
    if (max === b) h = (r - g) / d + 4;
    h /= 6;
  }
  return `hsl(${Math.round(h * 360)}, ${Math.round(s * 100)}%, ${Math.round(l * 100)}%)`;
})();

const initialRgb = (() => {
  const activeCol = defaultColors[0];
  if (!activeCol.startsWith('#')) return '255, 255, 255';
  const clean = activeCol.replace('#', '');
  const number = Number.parseInt(clean, 16);
  return `${(number >> 16) & 255}, ${(number >> 8) & 255}, ${number & 255}`;
})();
---

<section class="rounded-lg border border-hairline bg-canvas shadow-soft" aria-label={`${t(locale, 'site.title')} interactive screen`}>
  <div
    class="group relative grid min-h-[420px] overflow-hidden rounded-md border border-hairline"
    style={`background:${initialBackground};`}
    data-screen-tool
    data-tool-id={tool.id}
    data-mode={mode}
    data-initial-colors={JSON.stringify(defaultColors)}
    data-initial-color={color}
    data-initial-rgb={initialRgb}
    data-str-esc={t(locale, 'screen.fullscreen_hint')}
    data-str-fav-add={t(locale, 'screen.status_favorite_added')}
    data-str-fav-rm={t(locale, 'screen.status_favorite_removed')}
    data-str-already={t(locale, 'screen.status_already_saved')}
    data-str-hex-copied={t(locale, 'screen.status_hex_copied')}
    data-str-rgb-copied={t(locale, 'screen.status_rgb_copied')}
    data-str-color-copied={t(locale, 'screen.status_color_copied')}
    data-str-remove-fav={t(locale, 'screen.status_favorite_removed')}
  >
    <div class="pointer-events-none absolute inset-0 bg-black/0" data-dimmer></div>

    <button class="absolute right-3 top-3 z-20 grid size-11 place-items-center rounded-lg bg-black/25 text-white/90 opacity-100 shadow-xs ring-1 ring-white/15 backdrop-blur-xs transition-all hover:bg-black/45 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white" type="button" data-fullscreen-icon aria-label={t(locale, 'screen.fullscreen')}>
      <svg class="size-6.25" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M8 3H5a2 2 0 0 0-2 2v3" />
        <path d="M21 8V5a2 2 0 0 0-2-2h-3" />
        <path d="M16 21h3a2 2 0 0 0 2-2v-3" />
        <path d="M3 16v3a2 2 0 0 0 2 2h3" />
      </svg>
    </button>

    <div class="relative z-10 mt-auto bg-canvas/80 backdrop-blur-sm" data-controls-bar>
      <div class="divide-y divide-hairline/50">
        <div class="p-4 md:p-5">
          <div class="grid gap-4 md:grid-cols-[1fr_auto]">
            <div class="flex items-start gap-4">
              <div class="flex gap-2" data-swatch-list>
                {defaultColors.map((col, index) => (
                  <div class={`relative size-14 shrink-0 overflow-hidden rounded-lg border border-hairline shadow-xs md:size-16 cursor-pointer swatch-item transition-all ${index === 0 ? 'ring-2 ring-ink ring-offset-2 scale-105' : 'hover:scale-105'}`} data-index={index}>
                    <input class="absolute inset-0 cursor-pointer opacity-0" type="color" value={col} data-color-picker-item autocomplete="off" />
                    <div class="size-full" data-swatch-item-visual style={`background:${col};`}></div>
                  </div>
                ))}
              </div>
              <div class="grid min-w-0 flex-1 gap-2">
                <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
                  <label class="flex items-center gap-2 text-xs text-muted">
                    HEX
                    <input class="w-24 rounded-md border border-transparent bg-transparent px-1.5 py-0.5 font-mono text-sm text-ink outline-hidden transition-colors hover:border-hairline focus:border-hairline focus:bg-canvas" name="hex-color" value={defaultColors[0]} data-hex-input aria-label={t(locale, 'screen.hex_value')} autocomplete="off" spellcheck="false" inputmode="text" />
                  </label>
                  <label class="flex items-center gap-2 text-xs text-muted">
                    RGB
                    <input class="w-34 rounded-md border border-transparent bg-transparent px-1.5 py-0.5 font-mono text-sm text-ink outline-hidden transition-colors hover:border-hairline focus:border-hairline focus:bg-canvas" name="rgb-color" value={initialRgb} data-rgb-input aria-label={t(locale, 'screen.rgb_value')} autocomplete="off" spellcheck="false" inputmode="numeric" />
                  </label>
                  <label class="flex items-center gap-2 text-xs text-muted">
                    HSL
                    <input class="w-44 rounded-md border border-transparent bg-transparent px-1.5 py-0.5 font-mono text-sm text-ink outline-hidden transition-colors hover:border-hairline focus:border-hairline focus:bg-canvas md:w-52" name="hsl-color" value={initialHsl} data-hsl-input aria-label={t(locale, 'screen.hsl_value')} autocomplete="off" spellcheck="false" inputmode="text" />
                  </label>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-xs text-muted whitespace-nowrap">{t(locale, 'screen.brightness')}</span>
                  <input class="h-5 w-28 accent-ink md:w-36" name="brightness" type="range" min="20" max="120" value="100" data-brightness aria-label={t(locale, 'screen.brightness_label')} autocomplete="off" />
                </div>
              </div>
            </div>
            <div class="flex flex-wrap items-start gap-2">
              <button class="inline-flex h-8 items-center gap-1.5 rounded-lg bg-ink px-3.5 text-xs font-medium text-canvas hover:bg-body focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink transition-colors" type="button" data-fullscreen>
                <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/></svg>
                {t(locale, 'screen.fullscreen')}
              </button>
              <button class="inline-flex h-8 items-center gap-1.5 rounded-lg border border-hairline bg-canvas px-3 text-xs font-medium text-body hover:bg-canvas-soft hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink transition-colors" type="button" data-random>
                <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 3 21 3 21 8"/><line x1="4" x2="21" y1="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" x2="21" y1="15" y2="21"/></svg>
                {t(locale, 'screen.random')}
              </button>
              <button class="inline-flex h-8 items-center gap-1.5 rounded-lg border border-hairline bg-canvas px-3 text-xs font-medium text-body hover:bg-canvas-soft hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink transition-colors" type="button" data-favorite>
                <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {t(locale, 'screen.favorite')}
              </button>
            </div>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-2 px-4 py-3 md:px-5">
          <button class="inline-flex h-7 items-center gap-1 rounded-md px-2.5 text-xs font-medium text-muted hover:bg-canvas-soft hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink transition-colors" type="button" data-copy-hex>
            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            {t(locale, 'screen.copy_hex')}
          </button>
          <button class="inline-flex h-7 items-center gap-1 rounded-md px-2.5 text-xs font-medium text-muted hover:bg-canvas-soft hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink transition-colors" type="button" data-copy-rgb>
            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            {t(locale, 'screen.copy_rgb')}
          </button>
          <span aria-live="polite" data-status class="ml-auto text-xs text-muted"></span>
          <div class="flex flex-wrap gap-1.5" data-favorites aria-label={t(locale, 'screen.favorites')}></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function normalizeHex(value: string) {
    const trimmed = value.trim();
    if (/^#[0-9a-f]{6}$/i.test(trimmed)) return trimmed.toLowerCase();
    if (/^[0-9a-f]{6}$/i.test(trimmed)) return `#${trimmed.toLowerCase()}`;
    return null;
  }

  function hexToRgb(hex: string) {
    const clean = hex.replace('#', '');
    const number = Number.parseInt(clean, 16);
    return `${(number >> 16) & 255}, ${(number >> 8) & 255}, ${number & 255}`;
  }

  function hexToHsl(hex: string) {
    const [r, g, b] = hexToRgb(hex).split(', ').map((value) => Number(value) / 255);
    const max = Math.max(r, g, b);
    const min = Math.min(r, g, b);
    let h = 0;
    let s = 0;
    const l = (max + min) / 2;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      if (max === r) h = (g - b) / d + (g < b ? 6 : 0);
      if (max === g) h = (b - r) / d + 2;
      if (max === b) h = (r - g) / d + 4;
      h /= 6;
    }
    return `hsl(${Math.round(h * 360)}, ${Math.round(s * 100)}%, ${Math.round(l * 100)}%)`;
  }

  function hslToHex(value: string) {
    const match = value.match(/hsl\(?\s*(\d{1,3})[,\s]+(\d{1,3})%?[,\s]+(\d{1,3})%?\s*\)?/i);
    if (!match) return null;
    const h = Number(match[1]) / 360;
    const s = Number(match[2]) / 100;
    const l = Number(match[3]) / 100;
    const hue = (p: number, q: number, t: number) => {
      let next = t;
      if (next < 0) next += 1;
      if (next > 1) next -= 1;
      if (next < 1 / 6) return p + (q - p) * 6 * next;
      if (next < 1 / 2) return q;
      if (next < 2 / 3) return p + (q - p) * (2 / 3 - next) * 6;
      return p;
    };
    const q = l < 0.5 ? l * (1 + s) : l + s - l * s;
    const p = 2 * l - q;
    const rgb = s === 0 ? [l, l, l] : [hue(p, q, h + 1 / 3), hue(p, q, h), hue(p, q, h - 1 / 3)];
    return `#${rgb.map((channel) => Math.round(channel * 255).toString(16).padStart(2, '0')).join('')}`;
  }

  function rgbToHex(value: string) {
    const match = value.match(/(\d{1,3})\s*,\s*(\d{1,3})\s*,\s*(\d{1,3})/);
    if (!match) return null;
    const [r, g, b] = [Number(match[1]), Number(match[2]), Number(match[3])];
    if (r > 255 || g > 255 || b > 255) return null;
    return `#${[r, g, b].map((c) => c.toString(16).padStart(2, '0')).join('')}`;
  }

  function randomHex() {
    return `#${Math.floor(Math.random() * 0xffffff).toString(16).padStart(6, '0')}`;
  }

  for (const root of document.querySelectorAll<HTMLElement>('[data-screen-tool]')) {
    const str = (key: string) => root.dataset[key] ?? '';
    const hexInput = root.querySelector<HTMLInputElement>('[data-hex-input]');
    const rgbInput = root.querySelector<HTMLInputElement>('[data-rgb-input]');
    const hslInput = root.querySelector<HTMLInputElement>('[data-hsl-input]');
    const brightness = root.querySelector<HTMLInputElement>('[data-brightness]');
    const dimmer = root.querySelector<HTMLElement>('[data-dimmer]');
    const status = root.querySelector<HTMLElement>('[data-status]');
    const favorites = root.querySelector<HTMLElement>('[data-favorites]');
    const controlsBar = root.querySelector<HTMLElement>('[data-controls-bar]');

    const mode = root.dataset.mode || 'solid';
    let colors = JSON.parse(root.dataset.initialColors || '[]');
    let activeIndex = 0;

    const setStatus = (message: string) => {
      if (!status) return;
      status.textContent = message;
      window.setTimeout(() => {
        status.textContent = '';
      }, 1600);
    };

    const updateBackground = () => {
      if (mode === 'gradient') {
        root.style.background = `linear-gradient(135deg, ${colors[0]}, ${colors[1]})`;
      } else if (mode === 'rgb') {
        root.style.background = `linear-gradient(90deg, ${colors[0]} 0%, ${colors[0]} 33.3%, ${colors[1]} 33.3%, ${colors[1]} 66.6%, ${colors[2]} 66.6%, ${colors[2]} 100%)`;
      } else if (mode === 'hex') {
        root.style.background = `linear-gradient(90deg, ${colors[0]} 0%, ${colors[0]} 25%, ${colors[1]} 25%, ${colors[1]} 50%, ${colors[2]} 50%, ${colors[2]} 75%, ${colors[3]} 75%, ${colors[3]} 100%)`;
      } else {
        root.style.background = colors[0];
      }
    };

    const updateInputs = () => {
      const activeColor = colors[activeIndex];
      if (hexInput) hexInput.value = activeColor;
      if (rgbInput) rgbInput.value = hexToRgb(activeColor);
      if (hslInput) hslInput.value = hexToHsl(activeColor);
    };

    const setColors = (newColors: string[]) => {
      colors = newColors;
      const swatches = root.querySelectorAll<HTMLElement>('.swatch-item');
      colors.forEach((col: string, idx: number) => {
        const swatchVisual = swatches[idx]?.querySelector<HTMLElement>('[data-swatch-item-visual]');
        const pickerInput = swatches[idx]?.querySelector<HTMLInputElement>('[data-color-picker-item]');
        if (swatchVisual) swatchVisual.style.background = col;
        if (pickerInput) pickerInput.value = col;
      });
      updateBackground();
      updateInputs();
    };

    const selectSwatch = (index: number) => {
      activeIndex = index;
      const swatches = root.querySelectorAll<HTMLElement>('.swatch-item');
      swatches.forEach((swatch, idx) => {
        if (idx === index) {
          swatch.classList.add('ring-2', 'ring-ink', 'ring-offset-2', 'scale-105');
          swatch.classList.remove('hover:scale-105');
        } else {
          swatch.classList.remove('ring-2', 'ring-ink', 'ring-offset-2', 'scale-105');
          swatch.classList.add('hover:scale-105');
        }
      });
      updateInputs();
    };

    // Swatches Event Listeners
    const swatches = root.querySelectorAll<HTMLElement>('.swatch-item');
    swatches.forEach((swatch, idx) => {
      const pickerInput = swatch.querySelector<HTMLInputElement>('[data-color-picker-item]');
      pickerInput?.addEventListener('input', () => {
        const newColors = [...colors];
        newColors[idx] = pickerInput.value;
        setColors(newColors);
        selectSwatch(idx);
      });
      swatch.addEventListener('click', (e) => {
        if (e.target !== pickerInput) {
          selectSwatch(idx);
        }
      });
    });

    hexInput?.addEventListener('change', () => {
      const hex = normalizeHex(hexInput.value);
      if (hex) {
        const newColors = [...colors];
        newColors[activeIndex] = hex;
        setColors(newColors);
      }
    });
    hslInput?.addEventListener('change', () => {
      const hex = hslToHex(hslInput.value);
      if (hex) {
        const newColors = [...colors];
        newColors[activeIndex] = hex;
        setColors(newColors);
      }
    });
    rgbInput?.addEventListener('change', () => {
      const hex = rgbToHex(rgbInput.value);
      if (hex) {
        const newColors = [...colors];
        newColors[activeIndex] = hex;
        setColors(newColors);
      }
    });

    brightness?.addEventListener('input', () => {
      if (!dimmer) return;
      const value = Number(brightness.value);
      dimmer.style.background = value < 100 ? `rgb(0 0 0 / ${(100 - value) / 100})` : 'transparent';
      root.style.filter = value > 100 ? `brightness(${value}%)` : '';
    });

    const doFullscreen = () => root.requestFullscreen?.();
    for (const btn of root.querySelectorAll<HTMLElement>('[data-fullscreen], [data-fullscreen-icon]')) {
      btn.addEventListener('click', doFullscreen);
    }
    root.querySelector('[data-copy-hex]')?.addEventListener('click', async () => {
      await navigator.clipboard?.writeText(hexInput?.value ?? '');
      setStatus(str('strHexCopied'));
    });
    root.querySelector('[data-copy-rgb]')?.addEventListener('click', async () => {
      await navigator.clipboard?.writeText(rgbInput?.value ?? '');
      setStatus(str('strRgbCopied'));
    });

    const triggerRandom = () => {
      if (mode === 'gradient') {
        const c1 = randomHex();
        const c2 = randomHex();
        setColors([c1, c2]);
      } else if (mode === 'rgb') {
        const r = `#${Math.floor(100 + Math.random() * 156).toString(16).padStart(2, '0')}0000`;
        const g = `#00${Math.floor(100 + Math.random() * 156).toString(16).padStart(2, '0')}00`;
        const b = `#0000${Math.floor(100 + Math.random() * 156).toString(16).padStart(2, '0')}`;
        setColors([r, g, b]);
      } else if (mode === 'hex') {
        const c1 = randomHex();
        const c2 = randomHex();
        const c3 = randomHex();
        const c4 = randomHex();
        setColors([c1, c2, c3, c4]);
      } else {
        setColors([randomHex()]);
      }
    };

    root.querySelector('[data-random]')?.addEventListener('click', triggerRandom);

    document.addEventListener('fullscreenchange', () => {
      const isActive = document.fullscreenElement === root;
      root.classList.toggle('is-fullscreen', isActive);
      if (controlsBar) controlsBar.style.display = isActive ? 'none' : '';
      for (const btn of root.querySelectorAll<HTMLElement>('[data-fullscreen], [data-fullscreen-icon]')) {
        btn.style.display = isActive ? 'none' : '';
      }
    });

    document.addEventListener('keydown', async (event) => {
      if (event.target instanceof HTMLInputElement) return;
      if (event.key.toLowerCase() === 'f') root.requestFullscreen?.();
      if (event.key.toLowerCase() === 'r') triggerRandom();
      if (event.key.toLowerCase() === 'c') {
        await navigator.clipboard?.writeText(hexInput?.value ?? '');
        setStatus(str('strColorCopied'));
      }
    });

    const storageKey = 'freescreen-favorites';

    const loadFavorites = () => {
      if (!favorites) return;
      const stored = window.localStorage.getItem(storageKey);
      if (!stored) return;
      const hexes: string[] = JSON.parse(stored);
      for (const hex of hexes) {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'size-5 rounded-full border border-hairline ring-1 ring-inset ring-white/20 hover:ring-2 transition-shadow';
        button.style.background = hex;
        button.setAttribute('aria-label', `${str('strRemoveFav')} ${hex}`);
        button.addEventListener('click', () => {
          button.remove();
          const remaining = [...favorites.querySelectorAll('button')].map((b) => b.style.background);
          window.localStorage.setItem(storageKey, JSON.stringify(remaining));
          setStatus(str('strFavRm'));
        });
        favorites.append(button);
      }
    };

    const saveFavorites = (hex: string) => {
      const stored = window.localStorage.getItem(storageKey);
      const hexes: string[] = stored ? JSON.parse(stored) : [];
      if (!hexes.includes(hex)) {
        hexes.push(hex);
        window.localStorage.setItem(storageKey, JSON.stringify(hexes));
      }
    };

    loadFavorites();

    root.querySelector('[data-favorite]')?.addEventListener('click', () => {
      const hex = normalizeHex(hexInput?.value ?? '');
      if (!hex || !favorites) return;
      if ([...favorites.querySelectorAll('button')].some((b) => b.style.background === hex)) {
        setStatus(str('strAlready'));
        return;
      }
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'size-5 rounded-full border border-hairline ring-1 ring-inset ring-white/20 hover:ring-2 transition-shadow';
      button.style.background = hex;
      button.setAttribute('aria-label', `${str('strRemoveFav')} ${hex}`);
      button.addEventListener('click', () => {
        button.remove();
        const remaining = [...favorites.querySelectorAll('button')].map((b) => b.style.background);
        window.localStorage.setItem(storageKey, JSON.stringify(remaining));
        setStatus(str('strFavRm'));
      });
      favorites.append(button);
      saveFavorites(hex);
      setStatus(str('strFavAdd'));
    });
  }
</script>
