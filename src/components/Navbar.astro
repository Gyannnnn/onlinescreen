---
import { categories, tools, type ToolCategoryId } from '../data/tools';
import { localeOrder, locales, type Locale } from '../data/locales';
import { t } from '../data/translations';

type Props = {
  locale?: Locale;
  currentToolSlug?: string;
  currentToolLocalizedSlugs?: Partial<Record<Exclude<Locale, 'en'>, string>>;
};

const { locale = 'en', currentToolSlug, currentToolLocalizedSlugs } = Astro.props;
const categoryIds = Object.keys(categories) as ToolCategoryId[];

const searchData = tools.map(tool => ({
  slug: tool.slug,
  shortName: tool.shortName,
  category: tool.category,
}));
---

<header class="sticky top-0 z-40 border-b border-hairline bg-canvas/90 backdrop-blur">
  <div class="site-shell flex h-16 items-center justify-between gap-2 lg:gap-4">
    <div class="flex items-center gap-4 lg:gap-6">
      <a href="/" class="flex shrink-0 items-center gap-3 text-sm font-medium text-ink whitespace-nowrap" aria-label={`${t(locale, 'site.title')} home`}>
        <span class="grid size-7 place-items-center rounded-md bg-ink text-canvas">F</span>
        <span>{t(locale, 'site.title')}</span>
      </a>

      <nav class="hidden items-center lg:flex" aria-label="Primary navigation">
        <!-- <div class="group relative">
          <button class="rounded-full px-3 py-2 text-sm text-body hover:bg-canvas-soft-2 hover:text-ink whitespace-nowrap" type="button">
            {t(locale, 'nav.tools')}
          </button>
          <div class="invisible absolute left-1/2 top-full w-[720px] -translate-x-1/2 pt-3 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
            <div class="grid grid-cols-2 gap-4 rounded-lg border border-hairline bg-canvas p-5 shadow-soft">
              {categoryIds.map((categoryId) => (
                <section>
                  <h2 class="font-mono text-xs text-muted">{categories[categoryId].name}</h2>
                  <div class="mt-3 grid grid-cols-2 gap-1">
                    {tools.filter((tool) => tool.category === categoryId).slice(0, 8).map((tool) => (
                      <a class="rounded-md px-2 py-1.5 text-sm text-body hover:bg-canvas-soft hover:text-ink whitespace-nowrap" href={`/${tool.slug}/`}>
                        {tool.shortName}
                      </a>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </div>
        </div> -->
        <div class="hidden items-center gap-1 xl:flex">
          {categoryIds.map((categoryId) => (
            <a class="rounded-full px-3 py-2 text-sm text-body hover:bg-canvas-soft-2 hover:text-ink whitespace-nowrap" href={`/#${categoryId}`}>
              {categories[categoryId].name}
            </a>
          ))}
        </div>
      </nav>
    </div>

    <div class="hidden items-center gap-1.5 lg:flex">
      <div class="relative">
        <label class="sr-only" for="site-search">{t(locale, 'nav.search')}</label>
        <input
          id="site-search"
          name="site-search"
          type="search"
          placeholder={t(locale, 'nav.search')}
          autocomplete="off"
          class="h-9 w-32 rounded-md border border-hairline bg-canvas px-3 text-sm text-ink placeholder:text-muted lg:w-40 xl:w-52"
          data-tool-search
        />
      </div>
      <select class="h-9 rounded-md border border-hairline bg-canvas px-2 text-sm text-body" aria-label={t(locale, 'nav.language')} name="language" data-language-select data-slug-map={currentToolLocalizedSlugs ? JSON.stringify(currentToolLocalizedSlugs) : ''} data-current-slug={currentToolSlug ?? ''}>
        {localeOrder.map((locale) => <option value={locale}>{locales[locale].label}</option>)}
      </select>
      <button class="grid size-9 shrink-0 place-items-center rounded-full border border-hairline text-sm text-body hover:text-ink" type="button" aria-label={t(locale, 'nav.theme')} data-theme-toggle>
        <svg class="hidden size-5 [[data-theme=dark]_&]:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="size-5 fill-current [[data-theme=dark]_&]:hidden" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>
    </div>

    <div class="flex items-center gap-1.5 lg:hidden">
      <button class="grid size-9 shrink-0 place-items-center rounded-full border border-hairline text-sm text-body hover:text-ink" type="button" aria-label={t(locale, 'nav.theme')} data-theme-toggle>
        <svg class="hidden size-5 [[data-theme=dark]_&]:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="size-5 fill-current [[data-theme=dark]_&]:hidden" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>
      <button class="grid size-9 shrink-0 place-items-center rounded-md border border-hairline text-ink hover:text-body" type="button" aria-label="Open menu" data-mobile-menu-toggle>
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <template data-mobile-menu>
    <div class="fixed inset-0 z-50 flex" data-mobile-menu-overlay>
      <div class="absolute inset-0 bg-black/40" data-mobile-menu-backdrop></div>
      <div class="relative ml-auto flex h-full w-full max-w-sm flex-col bg-canvas shadow-soft">
        <div class="flex items-center justify-between border-b border-hairline px-4 py-4">
          <span class="text-sm font-medium text-ink">{t(locale, 'nav.menu')}</span>
          <button class="grid size-8 place-items-center rounded-md text-body hover:text-ink" type="button" aria-label="Close menu" data-mobile-menu-close>
            <svg class="size-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
          </button>
        </div>
        <div class="flex-1 overflow-y-auto px-4 py-4">
          <div class="relative mb-4">
            <label class="sr-only" for="drawer-search">{t(locale, 'nav.search_tools')}</label>
            <input id="drawer-search" name="drawer-search" type="search" placeholder={t(locale, 'nav.search_tools')} autocomplete="off" class="h-10 w-full rounded-md border border-hairline px-3 text-sm" data-tool-search />
          </div>
          <div class="border-b border-hairline pb-4 mb-4">
            <select class="h-9 w-full rounded-md border border-hairline bg-canvas px-2 text-sm text-body" aria-label={t(locale, 'nav.language')} name="language" data-language-select data-slug-map={currentToolLocalizedSlugs ? JSON.stringify(currentToolLocalizedSlugs) : ''} data-current-slug={currentToolSlug ?? ''}>
              {localeOrder.map((locale) => <option value={locale}>{locales[locale].label}</option>)}
            </select>
          </div>
          {categoryIds.map((categoryId) => (
            <div class="border-b border-hairline py-3">
              <h3 class="mb-2 font-mono text-xs text-muted">{categories[categoryId].name}</h3>
              <div class="grid grid-cols-2 gap-1">
                {tools.filter((tool) => tool.category === categoryId).map((tool) => (
                  <a class="rounded-md px-2 py-2 text-sm text-body hover:bg-canvas-soft hover:text-ink whitespace-nowrap" href={`/${tool.slug}/`}>{tool.shortName}</a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </template>
</header>

<div hidden data-search-data={JSON.stringify(searchData)}></div>
<script>
  const toolsData = JSON.parse(document.querySelector('[data-search-data]').getAttribute('data-search-data'));

  function createSearchDropdown(input) {
    const existing = input.parentElement.querySelector('[data-search-results]');
    if (existing) existing.remove();
    const dropdown = document.createElement('div');
    dropdown.dataset.searchResults = '';
    dropdown.className = 'absolute left-0 right-0 top-full z-50 mt-1 overflow-hidden rounded-lg border border-hairline bg-canvas shadow-soft';
    input.parentElement.appendChild(dropdown);
    return dropdown;
  }

  function renderResults(dropdown, query) {
    if (!query || query.length < 1) { dropdown.innerHTML = ''; dropdown.style.display = 'none'; return; }
    const q = query.toLowerCase();
    const matches = toolsData.filter(t => t.shortName.toLowerCase().includes(q) || t.slug.includes(q)).slice(0, 12);
    if (!matches.length) { dropdown.innerHTML = ''; dropdown.style.display = 'none'; return; }
    dropdown.style.display = '';
    dropdown.innerHTML = matches.map(t => `
      <a href="/${t.slug}/" class="flex items-center justify-between gap-3 px-3 py-2.5 text-sm text-body hover:bg-canvas-soft hover:text-ink transition-colors" data-search-item>
        <span>${t.shortName}</span>
        <span class="shrink-0 text-xs text-muted">${t.category}</span>
      </a>
    `).join('');
  }

  function navigateToFirst(input) {
    const dd = input.parentElement.querySelector('[data-search-results]');
    if (!dd || !dd.children.length) return;
    (dd.children[0] as HTMLAnchorElement).click();
  }

  document.addEventListener('input', (e) => {
    const input = (e.target as HTMLElement).closest<HTMLInputElement>('[data-tool-search]');
    if (!input) return;
    let dropdown = input.parentElement.querySelector('[data-search-results]');
    if (!dropdown) dropdown = createSearchDropdown(input);
    renderResults(dropdown, input.value);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const input = (e.target as HTMLElement).closest<HTMLInputElement>('[data-tool-search]');
    if (!input) return;
    navigateToFirst(input);
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const input = target.closest<HTMLInputElement>('[data-tool-search]');
    const item = target.closest<HTMLAnchorElement>('[data-search-item]');
    if (item || input) return;
    for (const dd of document.querySelectorAll('[data-search-results]')) {
      dd.innerHTML = '';
      dd.style.display = 'none';
    }
  });

  const localePrefixes = { en: '', es: '/es', pt: '/pt', fr: '/fr', de: '/de', hi: '/hi', ja: '/ja' };
  document.addEventListener('change', (e) => {
    const select = (e.target as HTMLElement).closest<HTMLSelectElement>('[data-language-select]');
    if (!select) return;
    const target = select.value;
    const slugMap = select.dataset.slugMap ? JSON.parse(select.dataset.slugMap) : {};
    const currentSlug = select.dataset.currentSlug ?? '';
    if (currentSlug && target !== 'en' && slugMap[target]) {
      location.href = localePrefixes[target] + '/' + slugMap[target] + '/';
    } else if (currentSlug && target === 'en') {
      location.href = '/' + currentSlug + '/';
    } else {
      location.href = localePrefixes[target] || '/';
    }
  });

  const currentLocale = Object.entries(localePrefixes).find(
    ([, p]) => p && location.pathname.startsWith(p + '/'),
  )?.[0] ?? 'en';
  for (const select of document.querySelectorAll('[data-language-select]')) {
    select.value = currentLocale;
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-theme-toggle]');
    if (!btn) return;
    const html = document.documentElement;
    const isDark = html.getAttribute('data-theme') === 'dark';
    if (isDark) {
      html.removeAttribute('data-theme');
      window.localStorage.setItem('freescreen-theme', 'light');
    } else {
      html.setAttribute('data-theme', 'dark');
      window.localStorage.setItem('freescreen-theme', 'dark');
    }
  });

  const menuToggle = document.querySelector('[data-mobile-menu-toggle]');
  const menuTemplate = document.querySelector('[data-mobile-menu]');
  if (menuToggle && menuTemplate) {
    menuToggle.addEventListener('click', () => {
      const content = menuTemplate.content.cloneNode(true) as DocumentFragment;
      const overlay = content.querySelector('[data-mobile-menu-overlay]')!;
      const backdrop = content.querySelector('[data-mobile-menu-backdrop]')!;
      const closeBtn = content.querySelector('[data-mobile-menu-close]')!;
      const drawerSelect = content.querySelector('[data-language-select]');
      if (drawerSelect) drawerSelect.value = currentLocale;
      document.body.appendChild(overlay);
      document.body.style.overflow = 'hidden';
      const close = () => { overlay.remove(); document.body.style.overflow = ''; };
      backdrop.addEventListener('click', close);
      closeBtn.addEventListener('click', close);
    });
  }
</script>
