---
import { categories, popularTools, tools, type ToolCategoryId } from '../data/tools';
import { localeOrder, locales, type Locale } from '../data/locales';
import { t, toolName } from '../data/translations';

type Props = {
  locale?: Locale;
};

const { locale = 'en' } = Astro.props;
const categoryIds = Object.keys(categories) as ToolCategoryId[];
---

<footer class="border-t border-hairline bg-canvas-soft">
  <div class="site-shell py-14">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_2fr]">
      <div class="max-w-sm">
        <a href="/" class="inline-flex items-center gap-3 text-sm font-medium text-ink">
          <span class="grid size-7 place-items-center rounded-md bg-ink text-canvas">F</span>
          <span>{t(locale, 'site.title')}</span>
        </a>
        <p class="mt-4 text-sm leading-6 text-muted">
          {t(locale, 'footer.description')}
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <div>
          <h2 class="font-mono text-xs text-muted">{t(locale, 'footer.categories')}</h2>
          <ul class="mt-3 grid gap-1.5">
            {categoryIds.map((categoryId) => (
              <li><a class="text-sm text-body hover:text-ink transition-colors" href={`/#${categoryId}`}>{categories[categoryId].name}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="font-mono text-xs text-muted">{t(locale, 'footer.popular')}</h2>
          <ul class="mt-3 grid gap-1.5">
            {popularTools.map((tool) => (
              <li><a class="text-sm text-body hover:text-ink transition-colors" href={`/${tool.slug}/`}>{toolName(locale, tool)}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="font-mono text-xs text-muted">{t(locale, 'footer.languages')}</h2>
          <ul class="mt-3 grid gap-1.5">
            {localeOrder.map((l) => (
              <li><a class="text-sm text-body hover:text-ink transition-colors" href={locales[l].pathPrefix || '/'}>{locales[l].label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="font-mono text-xs text-muted">{t(locale, 'footer.company')}</h2>
          <ul class="mt-3 grid gap-1.5">
            <li><a class="text-sm text-body hover:text-ink transition-colors" href="/about/">{t(locale, 'footer.about')}</a></li>
            <li><a class="text-sm text-body hover:text-ink transition-colors" href="/privacy/">{t(locale, 'footer.privacy')}</a></li>
            <li><a class="text-sm text-body hover:text-ink transition-colors" href="/contact/">{t(locale, 'footer.contact')}</a></li>
            <li><a class="text-sm text-body hover:text-ink transition-colors" href="https://github.com/anomalyco/freescreen" target="_blank" rel="noopener noreferrer">{t(locale, 'footer.github')}</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
  <div class="border-t border-hairline">
    <div class="site-shell flex flex-wrap items-center justify-between gap-4 py-5">
      <p class="text-xs text-muted">&copy; {new Date().getFullYear()} {t(locale, 'site.title')}.</p>
      <p class="text-sm text-muted">Made in India 🇮🇳</p>
    </div>
  </div>
</footer>
