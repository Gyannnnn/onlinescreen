---
import { categories, tools, type ToolCategoryId } from '../data/tools';
import { type Locale } from '../data/locales';
import { t, toolName } from '../data/translations';

type Props = {
  locale?: Locale;
};

const { locale = 'en' } = Astro.props;
const categoryIds = Object.keys(categories) as ToolCategoryId[];

type CategoryGroup = { id: ToolCategoryId; name: string; tools: typeof tools };
const toolsByCategory = categoryIds
  .map((id) => ({
    id,
    name: categories[id].name,
    tools: tools.filter((tool) => tool.category === id),
  }))
  .filter((c) => c.tools.length > 0) as CategoryGroup[];

const colors = toolsByCategory.find((c) => c.id === 'colors')!;
const others = toolsByCategory.filter((c) => c.id !== 'colors');
const half = Math.ceil(colors.tools.length / 2);
---

<footer class="border-t border-hairline bg-canvas-soft">
  <div class="site-shell py-14">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_2fr]">
      <div class="max-w-sm">
        <a href="/" class="inline-flex items-center gap-3 text-sm font-medium text-ink">
          <span class="grid size-7 place-items-center rounded-md bg-ink text-canvas">F</span>
          <span>{t(locale, 'site.title')}</span>
        </a>
        <p class="mt-4 text-sm leading-6 text-muted">
          {t(locale, 'footer.description')}
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-5">
        <div>
          <h2 class="font-mono text-xs text-muted">{colors.name}</h2>
          <ul class="mt-3 space-y-1.5">
            {colors.tools.slice(0, half).map((tool) => (
              <li>
                <a class="whitespace-nowrap text-sm text-body hover:text-ink transition-colors" href={`/${tool.slug}/`}>{toolName(locale, tool)}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="font-mono text-xs text-muted sr-only">{colors.name} (cont.)</h2>
          <ul class="mt-3 space-y-1.5 xl:mt-0">
            {colors.tools.slice(half).map((tool) => (
              <li>
                <a class="whitespace-nowrap text-sm text-body hover:text-ink transition-colors" href={`/${tool.slug}/`}>{toolName(locale, tool)}</a>
              </li>
            ))}
          </ul>
        </div>
        {others.map(({ id, name, tools: catTools }) => (
          <div>
            <h2 class="font-mono text-xs text-muted">{name}</h2>
            <ul class="mt-3 space-y-1.5">
              {catTools.map((tool) => (
                <li>
                  <a class="whitespace-nowrap text-sm text-body hover:text-ink transition-colors" href={`/${tool.slug}/`}>{toolName(locale, tool)}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="border-t border-hairline">
    <div class="site-shell flex flex-wrap items-center justify-between gap-4 py-5">
      <p class="text-xs text-muted">&copy; {new Date().getFullYear()} {t(locale, 'site.title')}.</p>
      <p class="text-xs text-muted">Made In India 🇮🇳</p>
      <nav class="flex flex-wrap gap-x-4 gap-y-1">
        <a class="text-xs text-muted hover:text-ink transition-colors" href="/about/">{t(locale, 'footer.about')}</a>
        <a class="text-xs text-muted hover:text-ink transition-colors" href="/privacy/">{t(locale, 'footer.privacy')}</a>
        <a class="text-xs text-muted hover:text-ink transition-colors" href="/contact/">{t(locale, 'footer.contact')}</a>
        
      </nav>
    </div>
  </div>
</footer>
