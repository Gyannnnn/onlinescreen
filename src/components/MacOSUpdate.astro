  function sc() { return scenarios[state.scenario] || scenarios.major; }

  function phaseFor(p) {
    const s = sc();
    for (let i = 0; i < s.phases.length; i++) {
      if (p >= s.phases[i].r[0] && p < s.phases[i].r[1]) return i;
    }
    return s.phases.length - 1;
  }
  function msgsFor(p) {
    return sc().phases[phaseFor(p)].m;
  }

  function setProgress(val) {
