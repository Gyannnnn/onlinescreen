    pctEl.textContent = Math.round(state.progress) + '%';
    updateStatus();
    updateEta();
  }

  function updateStatus() {
    const s = sc();
    headingEl.textContent = s.name;
    const ms = msgsFor(state.progress);
    if (ms !== state.lastMessages) {
      state.statusIndex = 0;
      state.lastMessages = ms;
    }
    statusEl.textContent = ms[state.statusIndex % ms.length];
  }

  function advanceStatus() {
    const ms = msgsFor(state.progress);
    state.statusIndex = (state.statusIndex + 1) % ms.length;
    statusEl.style.opacity = '0';
    setTimeout(() => {
      statusEl.textContent = ms[state.statusIndex];
      statusEl.style.opacity = '0.65';
    }, 300);
  }

  function updateEta() {
    if (state.paused || state.progress <= 0 || state.progress >= 100) {
      if (state.progress <= 0) {
        etaEl.textContent = 'Estimating time remaining…';
        etaEl.classList.remove('hidden');
      } else if (state.progress >= 100) {
        etaEl.textContent = 'Completing…';
      }
      return;
    }

    if (state.mode === 'timer' && state.timerStart) {
      const elapsed = (Date.now() - state.timerStart) / 1000;
      const total = state.timerDuration * 60;
      const r = Math.max(0, total - elapsed);
      etaEl.textContent = r < 60 ? 'Less than a minute remaining…' : 'About ' + Math.round(r / 60) + ' minutes remaining…';
      etaEl.classList.remove('hidden');
      return;
    }

    const recent = state.speedHistory;
    state.etaCooldown = Math.max(0, state.etaCooldown - 1);

    if (state.etaMode === 0 && state.etaCooldown <= 0) {
      state.etaMode = 1;
      state.etaCooldown = 3 + Math.floor(Math.random() * 8);
      etaEl.textContent = 'Estimating time remaining…';
      etaEl.classList.remove('hidden');
      return;
    }
    state.etaCooldown--;
    if (state.etaCooldown <= 0 && Math.random() < 0.06) {
      state.etaCooldown = 4 + Math.floor(Math.random() * 10);
      state.etaMode = state.etaMode === 1 ? 0 : 1;
      if (state.etaMode === 0) { etaEl.textContent = 'Estimating time remaining…'; return; }
    }

    if (state.etaMode === 1 && recent.length > 3) {
      const avg = recent.slice(-20).reduce((a,b) => a + b, 0) / Math.min(20, recent.length);
      if (avg > 0) {
        let remaining = (100 - state.progress) / avg * (0.6 + Math.random() * 0.5);
        if (Math.random() < 0.1) remaining *= 1.5 + Math.random() * 2;
        let text;
        if (remaining < 60) text = 'Less than a minute remaining…';
        else if (remaining < 120) text = 'About 1 minute remaining…';
        else if (remaining < 3600) text = 'About ' + Math.max(1, Math.round(remaining / 60)) + ' minutes remaining…';
        else text = 'About ' + (remaining / 60 / 60).toFixed(1) + ' hours remaining…';
        if (text !== state.lastEtaText) {
          etaEl.textContent = text;
          state.lastEtaText = text;
          etaEl.classList.remove('hidden');
        }
        return;
      }
    }
    if (state.etaMode === 0 || recent.length <= 3) {
      etaEl.textContent = 'Estimating time remaining…';
      etaEl.classList.remove('hidden');
    }
  }

  function realisticTick() {
    if (state.isPaused) {
      state.pauseTimer -= 50;
      if (state.pauseTimer <= 0) state.isPaused = false;
      return;
    }
    const base = 0.004 * (state.speed / 5);
    let inc = base;
    const p = state.progress;

    if (p < 3) inc = base * 0.08;
    else if (p < 10) inc = base * (0.12 + Math.random() * 0.2);
    else if (p < 20) inc = base * (0.3 + Math.random() * 0.5);
    else if (p < 40) inc = base * (0.5 + Math.random() * 0.7);
    else if (p < 60) inc = base * (0.4 + Math.random() * 0.6);
    else if (p < 75) inc = base * (0.25 + Math.random() * 0.4);
    else if (p < 88) inc = base * (0.15 + Math.random() * 0.25);
    else if (p < 97) inc = base * (0.06 + Math.random() * 0.12);
    else inc = base * (0.02 + Math.random() * 0.04);

    if (state.speed <= 2) inc *= 0.5;
    if (state.speed >= 9) inc *= 1.8;

    if (Math.random() < 0.005) inc += (0.3 + Math.random() * 1.5) * (state.speed / 5);
    if (Math.random() < 0.001) inc += (2 + Math.random() * 3);

    const stick = [10, 18, 30, 42, 55, 68, 78, 85, 92, 96, 98];
    for (const s of stick) {
      if (Math.abs(p - s) < 0.3 && Math.random() < 0.025) {
        state.isPaused = true;
        state.pauseTimer = 2000 + Math.random() * 4000;
        return;
      }
    }

    if (Math.random() < 0.003) {
      state.isPaused = true;
      state.pauseTimer = 1500 + Math.random() * 3500;
      return;
    }

    const np = p + inc;
    if (np >= 100) return;
    setProgress(np);
    state.speedHistory.push(inc);
    if (state.speedHistory.length > 80) state.speedHistory.shift();
    if (Math.random() < 0.007) advanceStatus();
  }

  function timerTick() {
    if (!state.timerStart) return;
    const elapsed = (Date.now() - state.timerStart) / 1000;
    const total = state.timerDuration * 60;
    const expected = (elapsed / total) * 100;
    if (expected >= 100) { setProgress(100); return; }
    setProgress(expected);
    if (Math.random() < 0.01) advanceStatus();
  }

  function infiniteTick() {
    if (state.isPaused) {
      state.pauseTimer -= 50;
      if (state.pauseTimer <= 0) state.isPaused = false;
      return;
    }
    let inc = 0.003 * (state.speed / 5);
    const p = state.progress;
    if (p > 95) {
      inc *= 0.1;
      if (Math.random() < 0.01) { state.isPaused = true; state.pauseTimer = 3000 + Math.random() * 4000; return; }
      if (Math.random() < 0.001) { setProgress(0); return; }
    } else if (p > 85) inc *= 0.3;
    if (Math.random() < 0.004) { state.isPaused = true; state.pauseTimer = 2000 + Math.random() * 3000; return; }
    if (Math.random() < 0.004) inc += (0.3 + Math.random()) * (state.speed / 5);
    const np = p + inc;
    if (np > 99.5) { setProgress(99.5); return; }
    setProgress(np);
    state.speedHistory.push(inc);
    if (state.speedHistory.length > 80) state.speedHistory.shift();
    if (Math.random() < 0.006) advanceStatus();
  }

  function manualTick() {
    if (state.manualValue !== state.progress) setProgress(state.manualValue);
