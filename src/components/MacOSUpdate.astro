  };

  const scenarios = {
    major: { name: 'macOS Sequoia 15.5', phases: [
      { r: [0,4], m: ['Preparing…', 'Checking system volume…', 'Getting ready…'] },
      { r: [4,14], m: ['Configuring installation…', 'Preparing volume…', 'Setting up installation…'] },
      { r: [14,44], m: ['Installing…', 'Writing system files…', 'Installing system content…'] },
      { r: [44,64], m: ['Optimizing system performance…', 'Configuring system…', 'Applying system optimizations…'] },
      { r: [64,80], m: ['Applying updates…', 'Updating system components…', 'Migrating system data…'] },
      { r: [80,92], m: ['Cleaning up…', 'Performing cleanup…', 'Removing temporary files…'] },
      { r: [92,100], m: ['Finalizing…', 'Almost done…', 'Completing installation…'] },
    ]},
    security: { name: 'macOS Security Response 7.2', phases: [
      { r: [0,6], m: ['Preparing security response…', 'Verifying security patch…'] },
      { r: [6,26], m: ['Installing security update…', 'Applying security patch…'] },
      { r: [26,50], m: ['Applying security patches…', 'Patching system frameworks…'] },
      { r: [50,70], m: ['Verifying integrity…', 'Validating system security…'] },
      { r: [70,86], m: ['Optimizing…', 'Configuring security settings…'] },
      { r: [86,100], m: ['Finalizing…', 'Completing security update…'] },
    ]},
    app: { name: 'App Store Update', phases: [
      { r: [0,6], m: ['Preparing update…', 'Checking app integrity…'] },
      { r: [6,30], m: ['Downloading assets…', 'Downloading update content…'] },
      { r: [30,58], m: ['Installing update…', 'Writing app files…'] },
      { r: [58,78], m: ['Verifying…', 'Validating installation…'] },
      { r: [78,100], m: ['Finalizing…', 'Completing installation…'] },
    ]},
    firmware: { name: 'BridgeOS Firmware Update', phases: [
      { r: [0,3], m: ['Preparing firmware…', 'Verifying firmware signature…'] },
      { r: [3,10], m: ['Verifying firmware…', 'Checking firmware integrity…'] },
      { r: [10,40], m: ['Installing firmware…', 'Writing firmware data…'] },
      { r: [40,66], m: ['Configuring system controller…', 'Updating chipset firmware…'] },
      { r: [66,82], m: ['Optimizing…', 'Applying firmware settings…'] },
      { r: [82,100], m: ['Finalizing…', 'Completing firmware update…'] },
    ]},
    beta: { name: 'macOS Sequoia 16.0 Beta', phases: [
      { r: [0,3], m: ['Preparing beta update…', 'Checking compatibility…'] },
      { r: [3,11], m: ['Configuring beta installation…', 'Preparing beta volume…'] },
      { r: [11,42], m: ['Installing beta…', 'Writing beta system files…'] },
      { r: [42,62], m: ['Optimizing system…', 'Configuring beta features…'] },
      { r: [62,78], m: ['Applying beta updates…', 'Updating beta components…'] },
