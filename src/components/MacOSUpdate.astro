    pauseTimer: 0,
    isPaused: false,
    statusIndex: 0,
    statusTimer: 0,
    lastMessages: null,
    restarting: false,
    restartCount: 0,
    speedHistory: [],
    etaMode: 0,
    etaCooldown: 0,
