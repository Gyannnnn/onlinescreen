---
import type { Tool } from '../data/tools';
import type { Locale } from '../data/locales';
import ReactRainScreen from './RainScreen.tsx';
import fs from 'fs';
import path from 'path';

type Props = { tool: Tool; locale: Locale };
const { tool, locale } = Astro.props;

// Dynamically read background image files from public/assets/rain-screen/backgrounds
const bgDir = path.join(process.cwd(), 'public/assets/rain-screen/backgrounds');
let backgrounds: string[] = [];
try {
  if (fs.existsSync(bgDir)) {
    backgrounds = fs.readdirSync(bgDir)
      .filter(file => {
        const ext = path.extname(file).toLowerCase();
        return ['.png', '.jpg', '.jpeg', '.webp', '.svg'].includes(ext);
      })
      .map(file => `/assets/rain-screen/backgrounds/${file}`);
  }
} catch (err) {
  console.error("Failed to read rain backgrounds directory:", err);
}

// Dynamically read audio files from public/assets/rain-screen/bgm
const bgmDir = path.join(process.cwd(), 'public/assets/rain-screen/bgm');
let audioFiles: string[] = [];
try {
  if (fs.existsSync(bgmDir)) {
    audioFiles = fs.readdirSync(bgmDir)
      .filter(file => {
        const ext = path.extname(file).toLowerCase();
        return ['.mp3', '.ogg', '.wav', '.m4a'].includes(ext);
      })
      .map(file => `/assets/rain-screen/bgm/${file}`);
  }
} catch (err) {
  console.error("Failed to read rain bgm directory:", err);
}
---

<ReactRainScreen 
  tool={tool} 
  locale={locale} 
  backgrounds={backgrounds} 
  audioFiles={audioFiles} 
  client:only="react" 
/>

<style>
  /* Vignette Overlay */
  .bg-radial-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at center, transparent 30%, rgba(0, 0, 0, 0.5) 100%);
    z-index: 6;
  }

  /* Dual Range Slider Thumb CSS overrides */
  :global(.slider-thumb-pointer) {
    pointer-events: none;
  }

  :global(.slider-thumb-pointer::-webkit-slider-thumb) {
    pointer-events: auto !important;
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #ffffff !important;
    border: 2px solid #38bdf8 !important;
    box-shadow: 0 0 10px rgba(56, 189, 248, 0.5), 0 2px 4px rgba(0, 0, 0, 0.3) !important;
    cursor: pointer;
    transition: transform 0.15s ease, border-color 0.15s, background-color 0.15s;
  }

  :global(.slider-thumb-pointer::-webkit-slider-thumb:hover) {
    transform: scale(1.25);
    background: #38bdf8 !important;
    border-color: #ffffff !important;
  }

  :global(.slider-thumb-pointer::-moz-range-thumb) {
    pointer-events: auto !important;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #ffffff !important;
    border: 2px solid #38bdf8 !important;
    box-shadow: 0 0 10px rgba(56, 189, 248, 0.5), 0 2px 4px rgba(0, 0, 0, 0.3) !important;
    cursor: pointer;
    transition: transform 0.15s ease, border-color 0.15s, background-color 0.15s;
  }

  :global(.slider-thumb-pointer::-moz-range-thumb:hover) {
    transform: scale(1.25);
    background: #38bdf8 !important;
    border-color: #ffffff !important;
  }

  /* Fade-in animation for secondary controls */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.animate-fadeIn) {
    animation: fadeIn 0.22s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  :global(.rain-container) {
    transition: none !important;
  }

  :global(.rain-container:fullscreen) {
    width: 100vw !important;
    height: 100vh !important;
    margin: 0 !important;
    max-width: none !important;
    max-height: none !important;
    border-radius: 0 !important;
    border: none !important;
  }

  :global(html.is-rain-fullscreen) {
    overflow: hidden !important;
  }
  :global(html.is-rain-fullscreen body) {
    overflow: hidden !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Thin premium custom scrollbar for drawer settings card */
  :global(.custom-scrollbar::-webkit-scrollbar) {
    width: 6px;
  }
  :global(.custom-scrollbar::-webkit-scrollbar-track) {
    background: transparent;
  }
  :global(.custom-scrollbar::-webkit-scrollbar-thumb) {
    background: rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
  }
  :global(.custom-scrollbar::-webkit-scrollbar-thumb:hover) {
    background: rgba(56, 189, 248, 0.4);
  }
</style>
