---
import type { Tool } from '../data/tools';
import type { Locale } from '../data/locales';
import ReactAmbientScreen from './AmbientScreen.tsx';
import fs from 'fs';
import path from 'path';

type Props = {
  tool: Tool;
  locale: Locale;
};

const { tool, locale } = Astro.props;

// Dynamically read audio files from public/assets/ambient-screen/bgm
const bgmDir = path.join(process.cwd(), 'public/assets/ambient-screen/bgm');
let ambientAudioFiles: string[] = [];
try {
  if (fs.existsSync(bgmDir)) {
    ambientAudioFiles = fs.readdirSync(bgmDir)
      .filter(file => {
        const ext = path.extname(file).toLowerCase();
        return ['.mp3', '.ogg', '.wav', '.m4a'].includes(ext);
      })
      .map(file => `/assets/ambient-screen/bgm/${file}`);
  }
} catch (err) {
  console.error("Failed to read ambient bgm directory:", err);
}
---

<ReactAmbientScreen 
  tool={tool} 
  locale={locale} 
  ambientAudioFiles={ambientAudioFiles}
  client:only="react" 
/>

<style>
  /* Ambient Fade-in animations for overlay modules */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.96) translateY(8px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
      filter: blur(0);
    }
  }

  :global(.animate-fadeIn) {
    animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  /* Fullscreen Mode fluid sizing & reset defaults */
  :global(.ambient-container:fullscreen) {
    width: 100vw !important;
    height: 100vh !important;
    margin: 0 !important;
    max-width: none !important;
    max-height: none !important;
    border-radius: 0 !important;
    border: none !important;
  }

  /* Hide scrollbar defaults inside custom settings drawer */
  :global(.custom-scrollbar::-webkit-scrollbar) {
    width: 5px;
    height: 5px;
  }
  :global(.custom-scrollbar::-webkit-scrollbar-track) {
    background: transparent;
  }
  :global(.custom-scrollbar::-webkit-scrollbar-thumb) {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 9999px;
  }
  :global(.custom-scrollbar::-webkit-scrollbar-thumb:hover) {
    background: rgba(255, 255, 255, 0.35);
  }
</style>
