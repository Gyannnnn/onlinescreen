---
import type { BootLogoConfig } from '../data/boot-screens';

type Props = {
  config: BootLogoConfig;
  class?: string;
};

const { config, class: className } = Astro.props;
---

{
  config.type === 'image' ? (
    <img
      src={config.src}
      alt={config.alt ?? ''}
      width={config.width}
      class={className}
      aria-hidden={config.alt ? undefined : 'true'}
    />
  ) : (
    <div
      class={`bs-wordmark ${className ?? ''}`}
      style={`font-size: ${config.fontSize}px;`}
      aria-hidden="true"
    >
      <span class="bs-wordmark-text">ubuntu</span>
      <svg class="bs-wordmark-mark" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
        <g transform="translate(50,50) scale(0.350877)">
          <circle fill="currentColor" r="141.732"/>
          <g id="bs-wm-friend">
            <circle cx="-96.3772" r="18.9215"/>
            <path d="M-45.6059,68.395C-62.1655,57.3316-74.4844,40.4175-79.6011,20.6065-73.623,15.7354-69.8047,8.3164-69.8047,0-69.8047-8.3164-73.623-15.7354-79.6011-20.6065-74.4844-40.4175-62.1655-57.3316-45.6059-68.395L-31.7715-45.2212C-45.9824-35.2197-55.2754-18.7026-55.2754,0-55.2754,18.7026-45.9824,35.2197-31.7715,45.2212Z"/>
          </g>
          <use href="#bs-wm-friend" transform="rotate(120)"/>
          <use href="#bs-wm-friend" transform="rotate(240)"/>
        </g>
      </svg>
    </div>
  )
}

<style>
  .bs-wordmark {
    display: flex;
    align-items: center;
    gap: 0.42em;
    color: #fff;
    font-family: 'Ubuntu', 'Ubuntu Beta', system-ui, sans-serif;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1;
    user-select: none;
  }
  .bs-wordmark-text {
    font-size: 1em;
    text-transform: lowercase;
  }
  .bs-wordmark-mark {
    width: 0.92em;
    height: 0.92em;
    flex-shrink: 0;
  }
</style>
