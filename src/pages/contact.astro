---
import BaseLayout from '../layouts/BaseLayout.astro';
import { locales } from '../data/locales';
---

<BaseLayout
  title="Contact Us - Free Online Screen"
  description="Contact the team behind Free Online Screen. We would love to hear your feedback, tool suggestions, or bug reports."
  canonicalPath="/contact/"
  lang={locales.en.lang}
  locale="en"
>
  <section class="site-shell py-16 md:py-24">
    <div class="max-w-3xl">
      <p class="font-mono text-xs text-muted uppercase tracking-wider">Get in Touch</p>
      <h1 class="mt-4 text-5xl font-semibold leading-[0.95] text-balance text-ink md:text-6xl">Contact Us.</h1>
      <p class="mt-6 text-lg leading-8 text-body text-balance">
        Have questions, suggestions, feedback, or a new tool request? Drop us a line, and we'll reply as soon as possible.
      </p>
    </div>
  </section>

  <section class="border-y border-hairline bg-canvas">
    <div class="site-shell py-12 md:py-16">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.5fr] lg:gap-16">
        <!-- Sidebar context -->
        <div class="space-y-8">
          <div>
            <h2 class="font-mono text-xs text-muted uppercase tracking-wider">Direct Contact</h2>
            <p class="mt-3 text-sm leading-6 text-body">
              Prefer writing a direct email? You can skip the form and reach us directly at:
            </p>
            <p class="mt-2">
              <a href="mailto:hello@freeonlinescreen.com" class="text-sm font-medium text-ink hover:text-link underline underline-offset-4 transition-colors">
                hello@freeonlinescreen.com
              </a>
            </p>
          </div>

          <div>
            <h2 class="font-mono text-xs text-muted uppercase tracking-wider">Response Time</h2>
            <p class="mt-3 text-sm leading-6 text-body">
              We typically review and reply to all feedback, bugs, and queries within <strong>24 hours</strong>.
            </p>
          </div>

          <div>
            <h2 class="font-mono text-xs text-muted uppercase tracking-wider">Bug Reports</h2>
            <p class="mt-3 text-sm leading-6 text-body">
              When reporting a diagnostic issue, please specify:
            </p>
            <ul class="mt-2 list-disc pl-5 text-sm leading-6 text-body space-y-1">
              <li>Your device model (e.g. Macbook Pro, Smart TV)</li>
              <li>Your web browser (e.g. Chrome, Safari)</li>
              <li>Screen resolution or aspect ratio</li>
            </ul>
          </div>
        </div>

        <!-- Form box -->
        <div class="relative rounded-xl border border-hairline bg-canvas-soft p-6 md:p-8 shadow-soft">
          <!-- Form State -->
          <div id="form-container">
            <form id="contact-form" class="space-y-6">
              <div class="grid gap-6 sm:grid-cols-2">
                <div>
                  <label for="contact-name" class="block font-mono text-xs text-muted uppercase tracking-wider mb-2">
                    Your Name
                  </label>
                  <input
                    type="text"
                    id="contact-name"
                    name="name"
                    required
                    placeholder="John Doe"
                    class="w-full h-10 px-3 bg-canvas text-ink border border-hairline rounded-md focus:outline-none focus:ring-2 focus:ring-ink focus:border-transparent transition-all placeholder:text-muted/50 text-sm"
                  />
                </div>
                <div>
                  <label for="contact-email" class="block font-mono text-xs text-muted uppercase tracking-wider mb-2">
                    Email Address
                  </label>
                  <input
                    type="email"
                    id="contact-email"
                    name="email"
                    required
                    placeholder="john@example.com"
                    class="w-full h-10 px-3 bg-canvas text-ink border border-hairline rounded-md focus:outline-none focus:ring-2 focus:ring-ink focus:border-transparent transition-all placeholder:text-muted/50 text-sm"
                  />
                </div>
              </div>

              <div>
                <label for="contact-subject" class="block font-mono text-xs text-muted uppercase tracking-wider mb-2">
                  Subject
                </label>
                <input
                  type="text"
                  id="contact-subject"
                  name="subject"
                  required
                  placeholder="Feedback, Feature Request, Bug Report"
                  class="w-full h-10 px-3 bg-canvas text-ink border border-hairline rounded-md focus:outline-none focus:ring-2 focus:ring-ink focus:border-transparent transition-all placeholder:text-muted/50 text-sm"
                />
              </div>

              <div>
                <label for="contact-message" class="block font-mono text-xs text-muted uppercase tracking-wider mb-2">
                  Message
                </label>
                <textarea
                  id="contact-message"
                  name="message"
                  required
                  rows="6"
                  placeholder="Details about your inquiry, bug details, or tool requests..."
                  class="w-full p-3 bg-canvas text-ink border border-hairline rounded-md focus:outline-none focus:ring-2 focus:ring-ink focus:border-transparent transition-all placeholder:text-muted/50 text-sm resize-y"
                ></textarea>
              </div>

              <div class="flex items-center justify-end">
                <button
                  type="submit"
                  id="submit-btn"
                  class="inline-flex items-center justify-center gap-2 rounded-full bg-ink px-6 py-3 text-sm font-medium text-canvas hover:bg-body disabled:opacity-50 disabled:cursor-not-allowed transition-all cursor-pointer"
                >
                  <span class="btn-text">Send Message</span>
                  <svg
                    class="btn-spinner hidden size-4 animate-spin text-canvas"
                    fill="none"
                    viewBox="0 0 24 24"
                  >
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </button>
              </div>
            </form>
          </div>

          <!-- Success Modal State (Hidden Initially) -->
          <div id="success-container" class="hidden py-8 text-center space-y-6">
            <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 dark:bg-emerald-950/30 dark:text-emerald-400">
              <svg class="size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
              </svg>
            </div>
            
            <div class="space-y-2">
              <h3 class="text-2xl font-semibold text-ink">Message Sent!</h3>
              <p class="mx-auto max-w-md text-sm text-body leading-relaxed">
                Thank you for contacting us. We've received your submission, and our team will get in touch with you shortly.
              </p>
            </div>

            <div class="pt-4">
              <button
                type="button"
                id="reset-btn"
                class="inline-flex rounded-full border border-hairline bg-canvas px-4 py-2.5 text-xs font-medium text-ink hover:bg-canvas-soft transition-colors cursor-pointer"
              >
                Send Another Message
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Dynamic handling of simulated form submit
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const successContainer = document.getElementById('success-container');
    const formContainer = document.getElementById('form-container');
    const submitButton = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const resetButton = document.getElementById('reset-btn') as HTMLButtonElement | null;

    if (form && successContainer && formContainer && submitButton) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();

        // Toggle Loading State
        const btnText = submitButton.querySelector('.btn-text');
        const btnSpinner = submitButton.querySelector('.btn-spinner');
        if (btnText) btnText.textContent = 'Sending...';
        if (btnSpinner) btnSpinner.classList.remove('hidden');
        submitButton.disabled = true;

        // Disable all form elements
        const inputs = form.querySelectorAll('input, textarea');
        inputs.forEach((input) => input.setAttribute('disabled', 'true'));

        // Simulate contact submission delay
        setTimeout(() => {
          formContainer.style.opacity = '0';
          formContainer.style.transition = 'opacity 0.2s ease-out';
          
          setTimeout(() => {
            formContainer.classList.add('hidden');
            successContainer.classList.remove('hidden');
            // Clean values for next time
            form.reset();
            inputs.forEach((input) => input.removeAttribute('disabled'));
            if (btnText) btnText.textContent = 'Send Message';
            if (btnSpinner) btnSpinner.classList.add('hidden');
            submitButton.disabled = false;
            formContainer.style.opacity = '';
          }, 200);
        }, 1200);
      });
    }

    if (resetButton && formContainer && successContainer) {
      resetButton.addEventListener('click', () => {
        successContainer.classList.add('hidden');
        formContainer.classList.remove('hidden');
      });
    }
  });
</script>
