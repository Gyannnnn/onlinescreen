---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePage from '../components/HomePage.astro';
import { alternatesForHome, landingJsonLd } from '../data/seo';
import { locales } from '../data/locales';
---

<BaseLayout
  title="Free Online Screen - Premium Fullscreen Utilities"
  description="Open fullscreen color screens, screen tests, screen savers, prank screens, and fake update screens from one fast, accessible web app."
  canonicalPath="/"
  lang={locales.en.lang}
  locale="en"
  alternates={alternatesForHome()}
  jsonLd={landingJsonLd()}
>
  <HomePage locale="en" />
</BaseLayout>
